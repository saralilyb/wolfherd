#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["anyio", "mcp>=1.26"]
# ///
"""Compatibility wrapper for `wolfherd reset` with uv-supplied deps."""

from pathlib import Path
import os
import sys

repo = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(repo))

from wolfherd.reset import reset  # noqa: E402

url = os.environ.get("WOLFHERD_URL") or "http://127.0.0.1:8765/mcp"
raise SystemExit(reset(url))
